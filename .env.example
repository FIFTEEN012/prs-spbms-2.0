# Supabase — Transaction mode (pooled, port 6543) สำหรับ app runtime
# ไปที่ Supabase dashboard → Project Settings → Database → Connection Pooling
# Mode: Transaction, แล้วคัดลอก URI
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase — Direct connection (port 5432) สำหรับ prisma migrate
# Project Settings → Database → Connection String → URI (ไม่ใช่ Pooler)
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3100"

# Integration test database: use a dedicated Supabase project/branch, never production.
TEST_DATABASE_URL="postgresql://postgres.[test-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
TEST_DIRECT_URL="postgresql://postgres:[password]@db.[test-ref].supabase.co:5432/postgres"

# One-time production bootstrap administrator. Do not commit real values.
BOOTSTRAP_ADMIN_USERNAME="admin"
BOOTSTRAP_ADMIN_PASSWORD="change-me-before-running-bootstrap"
BOOTSTRAP_ADMIN_FULL_NAME="ผู้ดูแลระบบ"

# Server-side only storage credentials for secured attachment uploads.
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="server-only-secret-key"
SUPABASE_STORAGE_BUCKET="school-documents"
